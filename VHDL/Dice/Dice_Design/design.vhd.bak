----------------------------------------------------------------------
-- Hierarchical Design of a Dice Device using AMBA APB To Communicate.
----------------------------------------------------------------------
library IEEE;
use IEEE.std_logic_1164.all;
use work.dice_pkg.all;
use work.apb_pkg.all;
use ieee.numeric_std.all;
	
entity dice is
  port (clk, reset, roll : in std_logic;
        valid            : out std_logic;
        segments         : out all_segmentsT);
end entity dice;

architecture rtl of dice is
  
  signal penable        : std_logic;
  signal psel           : std_logic;
  signal pready         : std_logic;
  signal pwrite         : std_logic;
  signal paddr          : apb_addr;
  signal pwdata         : apb_data;
  signal prdata         : apb_data;
  
  signal random_value, address_offset :
    std_logic_vector(2 downto 0);
  signal read_address : apb_addr;
  consim:/dice_tb/clock_periodstant address_zero_padding :
    std_logic_vector(1 to apb_addr_width -
                     random_value'length -
                     address_offset'length) := (others => '0');
    
  signal read_another         : std_logic;
  signal apb_setup_1          : std_logic;
  signal apb_setup_2          : std_logic;
  signal apb_capture_data     : std_logic;
  signal address_counter_en   : std_logic;
  signal random_value_en      : std_logic;
  signal segments_vector      : all_segments_vectorT;

  
  constant address_offset_limit : std_logic_vector :=
    std_logic_vector(to_unsigned(character_range'high, 3));
    
  signal limit : std_logic_vector (2 downto 0) := address_offset_limit;

  type stateT is (init,
                  start_read,
                  continue_read,
                  capture_data,
                  output_segments);

  signal state, next_state : stateT;
  signal Roll_Sync1, Roll_Sync2 : std_logic;

-- Top-level data inputs synchronization to reduce metastability  
begin
  Synchronizer : process(clk)
  begin
    if rising_edge(clk) then
      Roll_Sync1 <= roll;
      Roll_Sync2 <= Roll_Sync1;
    end if;
   end process;

-- Moore FSM Operations
              
  change_state : process (clk, reset)
  begin
    if reset = '1' then
      state <= init;
    elsif rising_edge(clk) then
      state <= next_state;
    end if;
  end process;
  
  read_another <= '1' when address_offset <= address_offset_limit else '0';
  
  calc_next_state : process (state, Roll_Sync2, read_another, address_offset)
  begin
    case state is
      when start_read =>
        next_state <= continue_read;
      when continue_read =>
        next_state <= capture_data;
      when capture_data =>
        if read_another = '1' then
          next_state <= start_read;
        else
          next_state <= output_segments;
        end if;  
      when output_segments | init =>
        if Roll_Sync2 = '1' then
          next_state <= start_read;
        else
          next_state <= init;
        end if;
    end case;
  end process;

  address_counter_en <=
    '1' when ((state = continue_read) or
              (state = output_segments)) else '0';
  
  valid <=
    '1' when (state = output_segments) else '0';
    
  apb_setup_1 <=
    '1' when (state = start_read) else '0';
    
  apb_setup_2 <=
    '1' when (state = continue_read) else '0';
    
  apb_capture_data <=
    '1' when (state = capture_data) else '0';
    
  random_value_en <=
    '0' when ((state = start_read) 
              or (state = continue_read)
              or (state = capture_data)) else '1';

-- Stores the word representation of the rolled dice values 
-- into an array of seven-segment display elements..    

  save_character : process (clk)
    variable char : integer range 0 to 7;
  begin
   if rising_edge(clk) then
     char := to_integer(unsigned(address_offset));
     if char >= 1 and char <= 5 then
       segments_vector(char) <= prdata(segment_range'high downto 0);
     end if;
   end if;
  end process;
  
  each_char : for i in character_range generate
    each_seg : for j in segment_range generate
      segments(i, j) <= segments_vector(i)(j);
    end generate;
  end generate;
 
-- The address used by the APB Mangaer to read the word representation 
-- of the rolled dice values from memory.

  read_address <= address_zero_padding & random_value & address_offset; 
 
 -- APB manager logic
  apb_control :
  process(apb_setup_1, apb_setup_2, apb_capture_data, read_address)
  begin
-- APB signals values for the first cycle of the APB read transaction.
    if apb_setup_1 = '1' then
    
      penable <= '0';
      psel <= '1';
      pwrite <= '0';
      paddr <= read_address;
      pwdata <= (others => '0');

 -- APB signals values for the second cycle of the APB read transaction.
    elsif apb_setup_2 = '1' then
      
      penable <= '1';
      psel <= '1';
      pwrite <= '0';
      paddr <= read_address;
      pwdata <= (others => '0');

 -- Assign the APB signals values appropriate for the idle cycle .  
    else

      penable <= '1';
      psel <= '0';
      pwrite <= '0';
      paddr <= (others => '0');
      pwdata <= (others => '0');

    end if;
  end process apb_control;

-- Port mapping of the instance of apb_mem (memory)
-- ports up to the APB signals.
  mem :
    entity work.apb_mem(behav)
    port map (reset => reset,
              pclk => clk,
              penable => penable,
              psel => psel,
              pready => pready,
              pwrite => pwrite,
              paddr => paddr,
              pwdata => pwdata,
              prdata => prdata);
      
-- Instances of cnt6 (counter) and connecting all ports as appropriate.

random_counter :
entity work.cnt6(RTL)
port map (Clock => clk,
          Reset => reset,
          Enable => random_value_en,
          Q => random_value);

address_counter :
entity work.cnt6(RTL)
port map (Clock => clk,
          Reset => reset,
          Enable => address_counter_en,
          Q => address_offset);
          
  assert pready /= '0'
    report "pready low - unsupported"
    severity failure;

  
end architecture rtl;
